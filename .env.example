# Template - copy to .env and fill in:
#   cp .env.example .env
#   chmod 600 .env
# For password-only login (no user) set FRITZ_USER=dslf-config

FRITZ_HOST=192.168.178.1
FRITZ_USER=fritz-capture-user
FRITZ_PW=

# --- Transport security -------------------------------------------------
# Plain HTTP leaks the session token AND every captured packet across your
# LAN/Wi-Fi in clear text. Strongly prefer HTTPS (true/false).
FRITZ_HTTPS=true
#
# IMPORTANT on cert verification (common first-run gotcha):
# The login API (login_sid.lua) answers only on the box's LAN IPv4 (FRITZ_HOST
# above) -- reaching it via the fritz.box hostname (IPv6/MyFRITZ) returns no
# login challenge. On that LAN IP the box presents a SELF-SIGNED certificate
# with NO IP SAN, so HTTPS verification + hostname check can never pass and
# pinning via FRITZ_CACERT does NOT help (the hostname check still fails on a
# bare IP). With FRITZ_HTTPS=true and verification on you will therefore get
# "CERTIFICATE_VERIFY_FAILED" and the capture won't start.
#
# Options:
#   * trusted wired LAN: set FRITZ_HTTPS_INSECURE=true -> encrypted (creds and
#     packets are not in clear text) but NOT authenticated (active MITM on the
#     LAN could impersonate the box). This is the usual working choice.
#   * FRITZ_CACERT only helps if you reach the box by a hostname that IS in the
#     cert SAN and resolves to it on the LAN; then set that name as FRITZ_HOST,
#     point FRITZ_CACERT at the box PEM, and keep FRITZ_HTTPS_INSECURE=false.
#   * last resort on a trusted LAN: FRITZ_HTTPS=false (plain HTTP, cleartext).
FRITZ_CACERT=
# Skips certificate checks entirely: the connection stays encrypted but is not
# authenticated (MITM-able on the LAN). Set true if verified TLS isn't reachable
# on your box (see above); leave false only when FRITZ_CACERT verifies cleanly.
FRITZ_HTTPS_INSECURE=false
# Pre-FRITZ!OS 7.24 boxes use a weak MD5 challenge-response login. It is
# refused by default so a man-in-the-middle can't force a downgrade. Only set
# this to true if your box genuinely runs that old firmware (true/false).
FRITZ_ALLOW_LEGACY=false

# --- Privacy ------------------------------------------------------------
# Redacted capture (true/false). When true, packet payloads are stripped and
# only the headers are recorded: you see how long each message was and between
# which addresses/ports it flowed, but NOT its contents. Useful for traffic
# analysis without storing private payloads. Default false (full capture).
FRITZ_REDACT=true
